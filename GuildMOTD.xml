<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"  xsi:schemaLocation="http://www.blizzard.com/wow/ui/..\..\FrameXML\UI.xsd">




<Frame name="GuildMOTDFrameOpts">
	<Layers>
		<Layer level="ARTWORK">
			<FontString name="$parent_Head" inherits="GameFontNormalLarge" text="GuildMOTD Options">
				<Anchors>
					<Anchor point="TOPLEFT">
						<Offset>
							<AbsDimension x="15" y="-15" />
						</Offset>
					</Anchor>
				</Anchors>
			</FontString>
		</Layer>
	</Layers>

		<Frames>

	<CheckButton name="GuildMOTDFrameOpts_ShowOnlyChanges" inherits="UICheckButtonTemplate">
				<Size>
					<AbsDimension x="32" y="32"/>
				</Size>

				<Anchors>
					<Anchor point="TOPLEFT" relativeTo="$parent_Head">
						<Offset>
							<AbsDimension x="25" y="-40"/>
						</Offset>
					</Anchor>
				</Anchors>
	</CheckButton>

	<CheckButton name="GuildMOTDFrameOpts_ShowOncePerSession" inherits="UICheckButtonTemplate">
				<Size>
					<AbsDimension x="32" y="32"/>
				</Size>

				<Anchors>
					<Anchor point="TOPLEFT" relativeTo="GuildMOTDFrameOpts_ShowOnlyChanges" relativePoint="BOTTOMLEFT">
						<Offset>
							<AbsDimension x="0" y="-5"/>
						</Offset>
					</Anchor>
				</Anchors>
	</CheckButton>

	<Slider name="GuildMOTDFrameOpts_OpacitySlider" inherits="OptionsSliderTemplate">
				<Size>
					<AbsDimension x="180" y="17"/>
				</Size>

				<Anchors>
					<Anchor point="TOPLEFT" relativeTo="GuildMOTDFrameOpts_ShowOncePerSession" relativePoint="BOTTOMLEFT">
						<Offset>
							<AbsDimension x="10" y="-30"/>
						</Offset>
					</Anchor>
				</Anchors>
	</Slider>
		</Frames>

        <Scripts>
            <OnLoad>
                GuildMOTDFrameOpts_OnLoad(self);
            </OnLoad>
        </Scripts>
    </Frame>
</Ui>
